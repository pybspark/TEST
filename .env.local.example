# ✅ Supabase 설정 (https://supabase.com 에서 새 프로젝트 만들고 복사)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# 가족 초대 시 사용할 앱 URL (로컬 개발 시 그대로)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# (선택) Word/Excel 미리보기용 변환 서비스. 설정하지 않으면 문서는 "새 탭에서 열기"만 표시됨
# 예: Docker 실행 후 GOTENBERG_URL=http://localhost:3000
# GOTENBERG_URL=
